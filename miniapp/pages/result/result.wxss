.result-hero,
.result-list,
.empty-result {
  background: var(--surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(255, 255, 255, 0.74);
  box-shadow: var(--shadow-sm);
}

.result-hero {
  overflow: hidden;
  margin-bottom: 24rpx;
}

.food-image {
  width: 100%;
  height: 360rpx;
}

.result-hero-copy {
  padding: 24rpx 28rpx 28rpx;
}

.result-hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 600;
}

.result-hero-sub {
  display: block;
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.result-list {
  overflow: hidden;
}

.food-card {
  padding: 28rpx;
  border-bottom: 1rpx solid var(--line);
}

.food-card:last-child {
  border-bottom: none;
}

.food-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.food-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
}

.food-confidence {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
}

.food-energy {
  text-align: right;
}

.food-energy-value {
  display: block;
  font-size: 52rpx;
  line-height: 1.02;
  font-weight: 500;
  color: var(--green-deep);
}

.food-energy-unit {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 20rpx;
}

.nutrition-row {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}

.nutrition-stat {
  flex: 1;
  padding: 20rpx 12rpx;
  background: rgba(255, 255, 255, 0.56);
  border-radius: var(--radius-md);
  text-align: center;
}

.ns-value {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
}

.ns-label {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 20rpx;
}

.editor-panel {
  margin-top: 22rpx;
  padding: 8rpx 0 0;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 84rpx;
  border-bottom: 1rpx solid var(--line);
}

.form-label {
  font-size: 26rpx;
}

.form-input,
.form-picker {
  width: 220rpx;
  text-align: right;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.empty-result {
  padding: 90rpx 40rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
}

.empty-hint {
  display: block;
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.result-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.result-actions button {
  flex: 1;
}

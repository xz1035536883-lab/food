.home-page {
  padding-top: 6rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.brand-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  letter-spacing: -1rpx;
}

.brand-sub {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.mini-avatar {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  background: #eee7dc;
}

.budget-card,
.overview-card,
.coach-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: var(--shadow-sm);
}

.budget-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  padding: 28rpx 30rpx 86rpx;
  overflow: hidden;
}

.budget-left {
  flex: 1;
}

.budget-label,
.budget-sub,
.score-title,
.score-state,
.recent-time,
.streak-note,
.coach-sign {
  color: var(--text-secondary);
}

.budget-label,
.score-title {
  display: block;
  font-size: 24rpx;
}

.budget-value-row {
  display: flex;
  align-items: flex-end;
  margin-top: 10rpx;
}

.budget-value {
  font-size: 74rpx;
  line-height: 1;
  font-weight: 500;
  color: var(--green-deep);
}

.budget-unit {
  margin-left: 8rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.budget-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
}

.budget-divider {
  width: 1rpx;
  align-self: stretch;
  background: var(--line);
  margin: 4rpx 24rpx 0;
}

.budget-right {
  width: 160rpx;
  position: relative;
  z-index: 1;
}

.score-value {
  display: block;
  margin-top: 12rpx;
  font-size: 60rpx;
  line-height: 1;
  font-weight: 500;
  color: var(--green-deep);
}

.score-state {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 78rpx;
  height: 42rpx;
  margin-top: 12rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: var(--green-soft);
  color: var(--green-deep);
  font-size: 22rpx;
  box-sizing: border-box;
}

.budget-progress {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 56rpx;
}

.budget-track {
  height: 10rpx;
  background: #E7E2D9;
  border-radius: 999rpx;
  overflow: hidden;
}

.budget-fill {
  height: 100%;
  background: linear-gradient(90deg, #8FBA8E, #6F9F72);
  border-radius: 999rpx;
}

.budget-footer {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.budget-arrow {
  font-size: 28rpx;
}

.capture-stage {
  position: relative;
  height: 560rpx;
  margin-top: 22rpx;
  margin-bottom: 24rpx;
}

.capture-ring {
  width: 456rpx;
  height: 456rpx;
  margin: 0 auto;
  padding: 12rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(143, 186, 142, 0.35);
  box-sizing: border-box;
}

.capture-bowl {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.capture-orb {
  position: absolute;
  left: 50%;
  bottom: 26rpx;
  transform: translateX(-50%);
  width: 216rpx;
  height: 216rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 20rpx 40rpx rgba(87, 78, 56, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.capture-orb-icon {
  font-size: 40rpx;
  line-height: 1;
  color: var(--green-deep);
}

.capture-orb-title {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.capture-orb-sub {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--text-secondary);
}

.capture-side {
  position: absolute;
  bottom: 116rpx;
  width: 92rpx;
  text-align: center;
  color: var(--text-secondary);
  font-size: 22rpx;
}

.capture-side.left {
  left: 16rpx;
}

.capture-side.right {
  right: 16rpx;
}

.capture-side-icon {
  display: block;
  width: 56rpx;
  height: 56rpx;
  margin: 0 auto 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: var(--shadow-sm);
  line-height: 56rpx;
}

.capture-overlay {
  position: absolute;
  inset: 0;
  background: rgba(50, 43, 34, 0.18);
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.spinner-ring {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.25);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.spinner-text {
  margin-top: 16rpx;
  color: #fff;
}

.overview-row {
  display: flex;
  gap: 16rpx;
}

.overview-card {
  flex: 1;
  padding: 22rpx;
}

.overview-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.overview-title,
.recent-name,
.coach-name {
  font-size: 26rpx;
  font-weight: 600;
}

.overview-link {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.streak-body {
  margin-top: 18rpx;
}

.streak-value {
  font-size: 58rpx;
  color: var(--green-deep);
  font-weight: 500;
}

.streak-unit {
  margin-left: 6rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.streak-note {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
}

.streak-dots {
  display: flex;
  gap: 10rpx;
  margin-top: 20rpx;
}

.streak-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #D8D2C8;
}

.streak-dot.filled {
  background: var(--green);
}

.recent-body {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
}

.recent-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 18rpx;
}

.recent-meta {
  flex: 1;
  margin-left: 16rpx;
  min-width: 0;
}

.recent-name {
  display: block;
  font-size: 24rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recent-time {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
}

.coach-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-top: 16rpx;
}

.coach-photo {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.coach-content {
  flex: 1;
  margin: 0 16rpx;
}

.coach-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.coach-sign {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
}

.coach-btn {
  min-height: 64rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
}

.profile-page {
  padding-top: 6rpx;
}

.plan-card,
.form-panel,
.login-panel,
.profile-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: var(--shadow-sm);
}

.plan-card,
.profile-card {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.profile-meta {
  flex: 1;
}

.profile-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.profile-sub,
.login-panel-text {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
  line-height: 1.7;
}

.profile-level {
  width: 132rpx;
  height: 132rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, rgba(111, 159, 114, 0.16) 0%, rgba(255, 255, 255, 0.72) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.profile-level-num {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--green-deep);
}

.profile-level-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--text-secondary);
}

.status-strip,
.quick-grid {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.status-item,
.quick-card {
  flex: 1;
  padding: 22rpx;
  border-radius: 24rpx;
  background: var(--surface);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: var(--shadow-sm);
}

.status-value {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--green-deep);
}

.status-label,
.quick-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.quick-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.hero-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 600;
}

.hero-metrics {
  display: flex;
  margin-top: 18rpx;
}

.hero-metric {
  flex: 1;
  padding: 0 12rpx;
  border-right: 1rpx solid var(--line);
}

.hero-metric:last-child {
  border-right: none;
}

.hero-metric-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.hero-metric-value {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 500;
}

.summary-note {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(247, 244, 238, 0.92);
  color: var(--text-secondary);
  font-size: 22rpx;
  line-height: 1.7;
}

.weight-record-row,
.weight-summary-grid {
  display: flex;
  gap: 14rpx;
}

.weight-record-row {
  margin-top: 18rpx;
  align-items: flex-end;
}

.weight-input-wrap {
  flex: 1;
}

.weight-input-label,
.weight-summary-label,
.weight-summary-note {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.weight-input-box {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  padding: 0 20rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid var(--line);
}

.weight-input {
  flex: 1;
  font-size: 34rpx;
  font-weight: 600;
}

.weight-input-unit {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.weight-save-btn {
  width: 168rpx;
  min-height: 88rpx;
}

.weight-summary-grid {
  margin-top: 16rpx;
}

.weight-summary-item {
  flex: 1;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.64);
}

.weight-summary-value {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--green-deep);
}

.weight-summary-note {
  margin-top: 8rpx;
}

.form-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid var(--line);
}

.form-cell-label {
  font-size: 28rpx;
}

.form-cell-input {
  width: 260rpx;
  text-align: right;
  font-size: 28rpx;
}

.gender-toggle {
  display: flex;
  gap: 8rpx;
  padding: 6rpx;
  background: var(--surface-soft);
  border-radius: 999rpx;
}

.gender-option {
  min-width: 96rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  color: var(--text-secondary);
  text-align: center;
  font-size: 24rpx;
}

.gender-option.active {
  background: #fff;
  color: var(--green-deep);
  box-shadow: 0 8rpx 18rpx rgba(80, 70, 54, 0.08);
}
